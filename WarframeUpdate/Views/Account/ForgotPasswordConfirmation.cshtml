@{
    ViewBag.Title = "Check Your Email";
}

<div class="auth-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-6 col-sm-8">
                <div class="card auth-card">
                    <div class="card-header auth-card-header">
                        <div class="text-center">
                            <div class="auth-icon">📧</div>
                            <h2 class="auth-title">TRANSMISSION SENT</h2>
                            <p class="auth-subtitle">AWAITING CONFIRMATION</p>
                        </div>
                    </div>

                    <div class="card-body auth-card-body text-center" style="padding: 2rem;">
                        <span class="auth-confirm-icon info">✔</span>
                        <p class="auth-confirm-msg">
                            A password reset link has been dispatched to your registered email address.
                        </p>
                        <p class="auth-confirm-msg" style="font-size:0.8rem;">
                            Check your inbox and follow the instructions. The link will expire after a short time.
                        </p>
                        @Html.ActionLink("← RETURN TO LOGIN", "Login", "Account", new { }, new { @class = "btn btn-accent mt-2" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>