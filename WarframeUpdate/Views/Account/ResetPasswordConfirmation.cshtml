@{
    ViewBag.Title = "Password Reset";
}

<div class="auth-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-6 col-sm-8">
                <div class="card auth-card">
                    <div class="card-header auth-card-header">
                        <div class="text-center">
                            <div class="auth-icon">🔓</div>
                            <h2 class="auth-title">ACCESS RESTORED</h2>
                            <p class="auth-subtitle">PASSWORD UPDATED SUCCESSFULLY</p>
                        </div>
                    </div>

                    <div class="card-body auth-card-body text-center" style="padding: 2rem;">
                        <span class="auth-confirm-icon success">✔</span>
                        <p class="auth-confirm-msg">
                            Your password has been successfully reset. You can now log in with your new credentials.
                        </p>
                        @Html.ActionLink("PROCEED TO LOGIN", "Login", "Account", new { }, new { @class = "btn btn-accent mt-2", id = "loginLink" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>