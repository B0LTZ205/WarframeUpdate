@model WarframeUpdate.Models.ForgotPasswordViewModel
@{
    ViewBag.Title = "Forgot Password";
}

<div class="auth-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-6 col-sm-8">
                <div class="card auth-card">
                    <div class="card-header auth-card-header">
                        <div class="text-center">
                            <div class="auth-icon">🔑</div>
                            <h2 class="auth-title">RECOVER ACCESS</h2>
                            <p class="auth-subtitle">PASSWORD RESET PROTOCOL</p>
                        </div>
                    </div>

                    <div class="card-body auth-card-body">
                        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { role = "form" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "text-danger alert alert-danger mb-3" })

                            <p class="auth-confirm-msg" style="font-size:0.82rem; margin-bottom:1.25rem;">
                                Enter your account email address and we will send you a link to reset your password.
                            </p>

                            <div class="mb-4">
                                @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "your@email.com" })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                            </div>

                            <button type="submit" class="btn btn-accent btn-lg w-100">SEND RESET LINK</button>
                        }
                    </div>

                    <div class="card-footer auth-card-footer text-center">
                        <small>
                            Remembered your password?
                            @Html.ActionLink("Return to login", "Login", "Account", new { }, new { @class = "link-gold fw-bold" })
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}