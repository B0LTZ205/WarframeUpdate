@model WarframeUpdate.Controllers.AdminEditUserViewModel

@{
    ViewBag.Title = "Edit User";
}

<div class="auth-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7 col-sm-9">
                <div class="card auth-card">
                    <div class="card-header auth-card-header">
                        <div class="text-center">
                            <div class="auth-icon">✎</div>
                            <h2 class="auth-title">EDIT TENNO</h2>
                            <p class="auth-subtitle">MODIFY USER RECORD</p>
                        </div>
                    </div>

                    <div class="card-body auth-card-body">
                        @using (Html.BeginForm("EditUser", "Admin", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(m => m.Id)
                            @Html.ValidationSummary(false, "", new { @class = "val-summary" })

                            <div class="mb-3">
                                @Html.LabelFor(m => m.UserName, new { @class = "form-label" })
                                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "val-msg" })
                            </div>

                            <div class="mb-4">
                                @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email" })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "val-msg" })
                            </div>

                            <div class="mb-4" style="display:flex; align-items:center; gap:0.65rem; padding:0.65rem 0.85rem; background:var(--bg-card-alt); border:1px solid var(--border); border-radius:2px;">
                                @Html.CheckBoxFor(m => m.EmailConfirmed, new { @class = "form-check-input", style = "width:1rem; height:1rem; margin:0; flex-shrink:0;" })
                                <div>
                                    <span style="font-family:var(--font-hud); font-size:0.75rem; font-weight:600; letter-spacing:0.12em; color:var(--text-dim); display:block;">EMAIL CONFIRMED</span>
                                    <span style="font-family:var(--font-mono); font-size:0.65rem; color:var(--text-muted);">Mark account email as verified</span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-accent btn-lg w-100 mb-2">SAVE CHANGES</button>
                            @Html.ActionLink("← CANCEL", "UserDetails", "Admin", new { id = Model.Id }, new { @class = "btn btn-cancel-hud w-100 text-center" })
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
