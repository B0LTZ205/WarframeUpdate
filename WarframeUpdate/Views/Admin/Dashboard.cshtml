@model WarframeUpdate.Controllers.AdminDashboardViewModel
@{
    ViewBag.Title = "Admin Dashboard";
}

<div class="admin-dashboard-wrap">
    <h2 class="admin-page-title">⚙ ADMIN DASHBOARD</h2>

    <div class="stat-cards-row">
        <div class="stat-card stat-users">
            <div class="stat-label">TOTAL USERS</div>
            <div class="stat-value">@Model.TotalUsers</div>
            <a href="@Url.Action("Users", "Admin")" class="stat-sub" style="color:var(--accent);text-decoration:none;">View Users →</a>
        </div>
        <div class="stat-card stat-files">
            <div class="stat-label">TOTAL FILES</div>
            <div class="stat-value">@Model.TotalFileUploads</div>
            <div class="stat-sub">Across all users</div>
        </div>
        <div class="stat-card stat-subs">
            <div class="stat-label">SUBSCRIPTIONS</div>
            <div class="stat-value">@Model.TotalEventSubscriptions</div>
            <div class="stat-sub">Active subscriptions</div>
        </div>
        <div class="stat-card stat-activity">
            <div class="stat-label">RECENT ACTIVITY</div>
            <div class="stat-value">@Model.RecentActivityLogs.Count</div>
            <div class="stat-sub">Last 10 actions</div>
        </div>
    </div>

    <div class="admin-grid">
        <div class="admin-panel">
            <div class="admin-panel-header">📋 RECENT ACTIVITY LOG</div>
            <div class="admin-panel-body" style="padding:0;">
                @if (Model.RecentActivityLogs.Any())
                {
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ADMIN</th>
                                <th>ACTION</th>
                                <th>DETAILS</th>
                                <th>TIME</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.RecentActivityLogs)
                            {
                                <tr>
                                    <td>@log.AdminUser.UserName</td>
                                    <td><strong>@log.Action</strong></td>
                                    <td>@log.Details</td>
                                    <td><small>@log.CreatedAt.ToString("MMM dd, HH:mm")</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="error-state">No recent activity.</div>
                }
            </div>
        </div>

        <div class="admin-panel">
            <div class="admin-panel-header">⚡ QUICK ACTIONS</div>
            <div style="padding:0;">
                <a href="@Url.Action("Users", "Admin")" class="admin-quick-link">
                    <span><i class="fas fa-users"></i> Manage Users</span>
                    <i class="fas fa-chevron-right" style="font-size:0.6rem;"></i>
                </a>
                <a href="@Url.Action("ActivityLogs", "Admin")" class="admin-quick-link">
                    <span><i class="fas fa-history"></i> View All Logs</span>
                    <i class="fas fa-chevron-right" style="font-size:0.6rem;"></i>
                </a>
                <a href="@Url.Action("Index", "Home")" class="admin-quick-link">
                    <span><i class="fas fa-home"></i> Back to Home</span>
                    <i class="fas fa-chevron-right" style="font-size:0.6rem;"></i>
                </a>
            </div>
        </div>
    </div>
</div>
