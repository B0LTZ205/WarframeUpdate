@model PaginatedList<WarframeUpdate.Models.AdminActivityLog>

@{
    ViewBag.Title = "Activity Logs";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">📋 Admin Activity Logs</h2>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info">No activity logs found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Admin</th>
                        <th>Action</th>
                        <th>Details</th>
                        <th>Date & Time</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.Items)
                    {
                        <tr>
                            <td>@log.AdminUser.UserName</td>
                            <td><strong>@log.Action</strong></td>
                            <td>@log.Details</td>
                            <td>@log.CreatedAt.ToString("MMM dd, yyyy HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if (Model.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("ActivityLogs", "Admin", new { page = Model.PageIndex - 1 })">Previous</a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" href="@Url.Action("ActivityLogs", "Admin", new { page = i })">@i</a>
                    </li>
                }

                @if (Model.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("ActivityLogs", "Admin", new { page = Model.PageIndex + 1 })">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>