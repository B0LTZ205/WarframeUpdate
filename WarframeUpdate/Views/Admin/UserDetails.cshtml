@model WarframeUpdate.Controllers.AdminUserDetailsViewModel

@{
    ViewBag.Title = "User Details";
}



<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-12">
            <a href="@Url.Action("Users", "Admin")" class="btn btn-secondary mb-3">
                <i class="fas fa-arrow-left"></i> Back to Users
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="row">
        <!-- User Info -->
        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">👤 User Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Username:</strong> @Model.User.UserName</p>
                    <p><strong>Email:</strong> @Model.User.Email</p>
                    <p>
                        <strong>Email Confirmed:</strong>
                        <span class="badge @(Model.User.EmailConfirmed ? "bg-success" : "bg-warning")">
                            @(Model.User.EmailConfirmed ? "Yes" : "No")
                        </span>
                    </p>

                    @if (Model.UserProfile != null)
                    {
                        <hr />
                        <p><strong>First Name:</strong> @Model.UserProfile.FirstName</p>
                        <p><strong>Last Name:</strong> @Model.UserProfile.LastName</p>
                        if (!string.IsNullOrEmpty(Model.UserProfile.PhoneNumber))
                        {
                            <p><strong>Phone:</strong> @Model.UserProfile.PhoneNumber</p>
                        }
                        <p><strong>Member Since:</strong> @Model.UserProfile.CreatedAt.ToString("MMM dd, yyyy")</p>
                    }

                    @if (ViewBag.IsAdmin == true)
                    {
                        <span class="badge bg-warning text-dark">Admin</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Standard User</span>
                    }
                </div>
            </div>
        </div>



        <!-- Stats -->
        <div class="col-lg-8">
            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-4 bg-success text-white">
                        <div class="card-body">
                            <h6 class="card-title">Total Files Uploaded</h6>
                            <h2>@Model.FileUploads.Count</h2>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card mb-4 bg-info text-white">
                        <div class="card-body">
                            <h6 class="card-title">Event Subscriptions</h6>
                            <h2>@Model.EventSubscriptions.Where(s => s.IsSubscribed).Count()</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Files -->
    @if (Model.FileUploads.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">📁 Recent Files</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>File Name</th>
                                <th>Type</th>
                                <th>Size</th>
                                <th>Uploaded</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var file in Model.FileUploads.OrderByDescending(f => f.UploadedAt).Take(10))
                            {
                                <tr>
                                    <td>@file.OriginalFileName</td>
                                    <td><span class="badge bg-info">@file.FileType</span></td>
                                    <td>@FormatFileSize(file.FileSizeBytes)</td>
                                    <td>@file.UploadedAt.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Subscriptions -->
    @if (Model.EventSubscriptions.Any())
    {
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">📧 Event Subscriptions</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Event Type</th>
                                <th>Status</th>
                                <th>Subscribed Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sub in Model.EventSubscriptions)
                            {
                                <tr>
                                    <td>@sub.EventType</td>
                                    <td>
                                        <span class="badge @(sub.IsSubscribed ? "bg-success" : "bg-secondary")">
                                            @(sub.IsSubscribed ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>@sub.CreatedAt.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<div class="admin-management-section mt-4">

    <!-- Admin Role Card -->
    <div class="card admin-card mb-4">
        <div class="card-body">

            <h4 class="section-title">
                <i class="fas fa-shield-alt"></i>
                Admin Role
            </h4>

            @if (ViewBag.IsAdmin == true)
            {
                <div class="status-badge admin-badge">
                    ADMIN ACCESS GRANTED
                </div>

                using (Html.BeginForm("RemoveAdmin", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("id", Model.User.Id)

                    <button type="submit" class="btn btn-danger admin-btn mt-3">
                        Remove Admin Access
                    </button>
                }
            }
            else
            {
                <div class="status-badge user-badge">
                    STANDARD USER
                </div>

                using (Html.BeginForm("MakeAdmin", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("id", Model.User.Id)

                    <button type="submit" class="btn btn-success admin-btn mt-3">
                        Grant Admin Access
                    </button>
                }
            }

        </div>
    </div>

    <!-- Email Verification Card -->
    <div class="card admin-card">
        <div class="card-body">

            <h4 class="section-title">
                <i class="fas fa-envelope-check"></i>
                Email Verification
            </h4>

            @if (Model.User.EmailConfirmed)
            {
                <div class="status-badge verified-badge">
                    EMAIL VERIFIED
                </div>

                using (Html.BeginForm("UnconfirmEmail", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("id", Model.User.Id)

                    <button type="submit" class="btn btn-warning admin-btn mt-3">
                        Remove Verification
                    </button>
                }
            }
            else
            {
                <div class="status-badge unverified-badge">
                    EMAIL NOT VERIFIED
                </div>

                using (Html.BeginForm("ConfirmEmail", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("id", Model.User.Id)

                    <button type="submit" class="btn btn-primary admin-btn mt-3">
                        Force Verify Email
                    </button>
                }
            }

        </div>
    </div>

    <div class="card admin-card mt-4">
        <div class="card-body">
            <h4 class="section-title">
                <i class="fas fa-image"></i>
                Profile Picture Moderation
            </h4>

            @if (Model.UserProfile != null && !string.IsNullOrEmpty(Model.UserProfile.ProfilePictureUrl))
            {
                <button type="button"
                        class="btn btn-outline-info mt-2"
                        data-bs-toggle="modal"
                        data-bs-target="#profilePictureModal">
                    View Profile Picture
                </button>

                <div class="modal fade"
                     id="profilePictureModal"
                     tabindex="-1"
                     aria-labelledby="profilePictureModalLabel"
                     aria-hidden="true">

                    <div class="modal-dialog modal-dialog-centered modal-lg">

                        <div class="modal-content bg-dark text-light">

                            <div class="modal-header">
                                <h5 class="modal-title"
                                    id="profilePictureModalLabel">
                                    Profile Picture Preview
                                </h5>

                                <button type="button"
                                        class="btn-close btn-close-white"
                                        data-bs-dismiss="modal"
                                        aria-label="Close"></button>
                            </div>

                            <div class="modal-body text-center">

                                <img src="@Url.Content(Model.UserProfile.ProfilePictureUrl)"
                                     class="img-fluid rounded"
                                     style="max-height:70vh;" />

                            </div>

                        </div>
                    </div>
                </div>

                <p class="text-muted mt-3">
                    Remove this image if it violates rules or contains inappropriate content.
                </p>

                using (Html.BeginForm("DeleteProfilePicture", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("id", Model.User.Id)

                    <button type="submit"
                            class="btn btn-danger admin-btn mt-3"
                            onclick="return confirm('Are you sure you want to remove this profile picture?');">

                        Remove Profile Picture
                    </button>
                }
            }
            else
            {
                <div class="status-badge user-badge">
                    NO PROFILE PICTURE UPLOADED
                </div>
            }
        </div>
    </div>

</div>

@Html.ActionLink(
    "Edit User Info",
    "EditUser",
    "Admin",
    new { id = Model.User.Id },
    new { @class = "btn btn-primary mt-3" }
)


@functions {
    string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}