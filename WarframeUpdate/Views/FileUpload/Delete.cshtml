@model WarframeUpdate.Models.FileUpload

@{
    ViewBag.Title = "Delete File";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">⚠️ Delete File</h4>
                </div>

                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <strong>Are you sure?</strong> This action cannot be undone.
                    </div>

                    <div class="file-info">
                        <p><strong>File Name:</strong> @Model.OriginalFileName</p>
                        <p><strong>File Type:</strong> <span class="badge bg-info">@Model.FileType</span></p>
                        <p><strong>Size:</strong> @FormatFileSize(Model.FileSizeBytes)</p>
                        <p><strong>Uploaded:</strong> @Model.UploadedAt.ToString("MMM dd, yyyy HH:mm")</p>
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p><strong>Description:</strong> @Model.Description</p>
                        }
                    </div>

                    <hr />

                    <div class="d-flex gap-2">
                        @using (Html.BeginForm("Delete", "FileUpload", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger flex-grow-1">
                                <i class="fas fa-trash"></i> Delete Permanently
                            </button>
                        }
                        <a href="@Url.Action("Index", "FileUpload")" class="btn btn-secondary flex-grow-1">Cancel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}