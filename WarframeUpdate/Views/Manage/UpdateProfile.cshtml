@model UserProfile

@{
    ViewBag.Title = "Edit Profile";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">✏️ Edit Profile</h4>
                </div>

                <div class="card-body">
                    @using (Html.BeginForm("UpdateProfile", "Manage", FormMethod.Post, 
                        new { enctype = "multipart/form-data", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()

                        <!-- First Name -->
                        <div class="mb-3">
                            <label for="FirstName" class="form-label fw-bold">First Name</label>
                            <input type="text" id="FirstName" name="FirstName" class="form-control" 
                                   value="@Model.FirstName" placeholder="Enter your first name" />
                        </div>

                        <!-- Last Name -->
                        <div class="mb-3">
                            <label for="LastName" class="form-label fw-bold">Last Name</label>
                            <input type="text" id="LastName" name="LastName" class="form-control" 
                                   value="@Model.LastName" placeholder="Enter your last name" />
                        </div>

                        <!-- Phone Number -->
                        <div class="mb-3">
                            <label for="PhoneNumber" class="form-label fw-bold">Phone Number</label>
                            <input type="tel" id="PhoneNumber" name="PhoneNumber" class="form-control" 
                                   value="@Model.PhoneNumber" placeholder="(123) 456-7890" />
                        </div>

                        <!-- Profile Picture Upload -->
                        <div class="mb-3">
                            <label for="ProfilePicture" class="form-label fw-bold">
                                <i class="fas fa-image"></i> Profile Picture
                            </label>
                            <div class="input-group">
                                <input type="file" id="ProfilePicture" name="HttpPostedFileBase" 
                                       class="form-control" accept="image/*" />
                                <span class="input-group-text">
                                    <i class="fas fa-upload"></i>
                                </span>
                            </div>
                            <small class="form-text text-muted d-block mt-2">
                                Allowed formats: JPG, PNG, GIF (Max 5 MB)
                            </small>
                            
                            @if (Model != null && !string.IsNullOrEmpty(Model.ProfilePictureUrl))
                            {
                                <div class="mt-3">
                                    <p class="mb-2"><strong>Current Picture:</strong></p>
                                    <img src="@Model.ProfilePictureUrl" 
                                         alt="Current Profile Picture" 
                                         class="img-thumbnail" 
                                         style="max-width: 200px;" />
                                </div>
                            }
                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                            <a href="@Url.Action("Index", "Manage")" class="btn btn-secondary">Cancel</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Preview profile picture before upload
    document.getElementById('ProfilePicture').addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (!file) return;

        const maxSize = 5 * 1024 * 1024; // 5 MB
        const allowedExtensions = ['jpg', 'jpeg', 'png', 'gif'];

        const ext = file.name.split('.').pop().toLowerCase();

        if (file.size > maxSize) {
            alert('Profile picture must be less than 5 MB!');
            e.target.value = '';
            return;
        }

        if (!allowedExtensions.includes(ext)) {
            alert('Only image files (jpg, png, gif) are allowed!');
            e.target.value = '';
            return;
        }
    });
</script>