@model UserProfile
@{
    ViewBag.Title = "Edit Profile";
}

<div class="edit-profile-wrap">
    <div class="edit-profile-card">
        <div class="edit-profile-header">✏ EDIT PROFILE</div>
        <div class="edit-profile-body">
            @using (Html.BeginForm("UpdateProfile", "Manage", FormMethod.Post,
                new { enctype = "multipart/form-data", novalidate = "novalidate" }))
            {
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label for="FirstName" class="form-label">FIRST NAME</label>
                    <input type="text" id="FirstName" name="FirstName" class="form-control"
                           value="@Model.FirstName" placeholder="Enter your first name" />
                </div>

                <div class="mb-3">
                    <label for="LastName" class="form-label">LAST NAME</label>
                    <input type="text" id="LastName" name="LastName" class="form-control"
                           value="@Model.LastName" placeholder="Enter your last name" />
                </div>

                <div class="mb-3">
                    <label for="PhoneNumber" class="form-label">PHONE NUMBER</label>
                    <input type="tel" id="PhoneNumber" name="PhoneNumber" class="form-control"
                           value="@Model.PhoneNumber" placeholder="(123) 456-7890" />
                </div>

                <div class="mb-4">
                    <label for="ProfilePicture" class="form-label">PROFILE PICTURE</label>
                    <div class="input-group">
                        <input type="file" id="ProfilePicture" name="HttpPostedFileBase"
                               class="form-control" accept="image/*" />
                        <span class="input-group-text"><i class="fas fa-upload"></i></span>
                    </div>
                    <small class="form-text">Allowed: JPG, PNG, GIF — Max 5 MB</small>

                    @if (Model != null && !string.IsNullOrEmpty(Model.ProfilePictureUrl))
                    {
                        <div style="margin-top:0.75rem;">
                            <p style="font-family:var(--font-mono);font-size:0.6rem;color:var(--text-muted);margin-bottom:0.4rem;">CURRENT PICTURE</p>
                            <img src="@Model.ProfilePictureUrl" alt="Current Profile Picture"
                                 style="max-width:120px;border:1px solid var(--border);border-radius:2px;" />
                        </div>
                    }
                </div>

                <div style="display:flex;flex-direction:column;gap:0.5rem;">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save" style="margin-right:0.4rem;"></i> SAVE CHANGES
                    </button>
                    <a href="@Url.Action("Index", "Manage")" class="btn btn-secondary text-center">CANCEL</a>
                </div>
            }
        </div>
    </div>
</div>

<script>
    document.getElementById('ProfilePicture').addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) {
            alert('Profile picture must be less than 5 MB!');
            e.target.value = '';
            return;
        }
        const ext = file.name.split('.').pop().toLowerCase();
        if (!['jpg', 'jpeg', 'png', 'gif'].includes(ext)) {
            alert('Only image files (jpg, png, gif) are allowed!');
            e.target.value = '';
        }
    });
</script>
