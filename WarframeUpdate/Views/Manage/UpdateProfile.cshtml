@model WarframeUpdate.Models.UserProfile
@{
    ViewBag.Title = "Edit Profile";
}

<div class="edit-profile-wrap">
    <div class="edit-profile-card">
        <div class="edit-profile-header">✏ EDIT PROFILE</div>
        <div class="edit-profile-body">
            @using (Html.BeginForm("UpdateProfile", "Manage", FormMethod.Post,
                new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(false, "", new { @class = "val-summary" })

                <div class="mb-3">
                    @Html.LabelFor(m => m.FirstName, "FIRST NAME", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = "Enter your first name" })
                    @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "val-msg" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.LastName, "LAST NAME", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = "Enter your last name" })
                    @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "val-msg" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.PhoneNumber, "PHONE NUMBER", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control", placeholder = "(123) 456-7890", type = "tel" })
                    @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "val-msg" })
                </div>

                <div class="mb-4">
                    <label for="ProfilePicture" class="form-label">PROFILE PICTURE</label>
                    <div class="input-group">
                        <input type="file" id="ProfilePicture" name="HttpPostedFileBase"
                               class="form-control" accept="image/*" />
                        <span class="input-group-text"><i class="fas fa-upload"></i></span>
                    </div>
                    <small class="form-text">Allowed: JPG, PNG, GIF — Max 5 MB</small>
                    <span id="pictureError" class="inline-error"></span>

                    @if (Model != null && !string.IsNullOrEmpty(Model.ProfilePictureUrl))
                    {
                        <div style="margin-top:0.75rem;">
                            <p style="font-family:var(--font-mono);font-size:0.6rem;color:var(--text-muted);margin-bottom:0.4rem;">CURRENT PICTURE</p>
                            <img src="@Model.ProfilePictureUrl" alt="Current Profile Picture"
                                 style="max-width:120px;border:1px solid var(--border);border-radius:2px;" />
                        </div>
                    }
                </div>

                <div style="display:flex;flex-direction:column;gap:0.5rem;">
                    <button type="submit" id="profileSubmit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save" style="margin-right:0.4rem;"></i> SAVE CHANGES
                    </button>
                    <a href="@Url.Action("Index", "Manage")" class="btn btn-secondary text-center">CANCEL</a>
                </div>
            }
        </div>
    </div>
</div>

<script>
    (function () {
        var fileInput  = document.getElementById('ProfilePicture');
        var errorSpan  = document.getElementById('pictureError');
        var submitBtn  = document.getElementById('profileSubmit');
        var allowedExt = ['jpg', 'jpeg', 'png', 'gif'];
        var maxBytes   = 5 * 1024 * 1024;

        function showError(msg) {
            errorSpan.textContent = msg;
            errorSpan.classList.add('visible');
            fileInput.classList.add('input-validation-error');
            submitBtn.disabled = true;
        }

        function clearError() {
            errorSpan.textContent = '';
            errorSpan.classList.remove('visible');
            fileInput.classList.remove('input-validation-error');
            submitBtn.disabled = false;
        }

        fileInput.addEventListener('change', function () {
            var file = this.files[0];
            if (!file) { clearError(); return; }

            var ext = file.name.split('.').pop().toLowerCase();

            if (file.size > maxBytes) {
                showError('⚠ File is too large. Maximum size is 5 MB.');
                this.value = '';
                return;
            }
            if (!allowedExt.includes(ext)) {
                showError('⚠ Invalid file type. Allowed: JPG, PNG, GIF.');
                this.value = '';
                return;
            }
            clearError();
        });
    })();
</script>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
