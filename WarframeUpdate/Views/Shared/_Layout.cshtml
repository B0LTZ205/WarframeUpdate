<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Warframe Tracker</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Exo+2:wght@300;400;600&family=Share+Tech+Mono&display=swap"
          rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/Content/Site.css" />
</head>

<body>
    <div class="scan-line"></div>
    <div class="noise-overlay"></div>

    <header class="site-header">
        <div class="header-inner">
            <a href="@Url.Action("Index", "Home")" class="logo-block logo-link">
                <div class="logo-emblem">⬡</div>
                <div class="logo-text">
                    <span class="logo-main">WARFRAME</span>
                    <span class="logo-sub">MISSION TRACKER</span>
                </div>
            </a>
            <nav class="header-nav">
                <a href="@Url.Action("Index", "Home")" class="nav-link">HOME</a>
                <a href="#sortie" class="nav-link">SORTIE</a>
                <a href="#nightwave" class="nav-link">NIGHTWAVE</a>
                <a href="#fissures" class="nav-link">FISSURES</a>
                <a href="#voidtrader" class="nav-link">BARO</a>
                <a href="#invasions" class="nav-link">INVASIONS</a>

                <!-- Files Dropdown -->
                <!--<div class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="fileDropdown" role="button" data-bs-toggle="dropdown">
                        📁 Files
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="fileDropdown">
                        <li><a class="dropdown-item" href="@Url.Action("Index", "FileUpload")">My Files</a></li>
                        <li><a class="dropdown-item" href="@Url.Action("Upload", "FileUpload")">Upload File</a></li>
                    </ul>
                </div>-->

                @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                {
                    <div class="nav-item">
                        <a class="nav-link" href="@Url.Action("Dashboard", "Admin")">
                            ⚙️ Admin Panel
                        </a>
                    </div>
                }
            </nav>
            <div class="header-status">
                <span class="status-dot"></span>
                <span class="status-text">LOTUS ONLINE</span>
            </div>

            <!-- Authentication links -->
            <div class="auth-links">
                @if (User.Identity.IsAuthenticated)
                {
                    <ul class="nav navbar-nav navbar-right">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-circle"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Index", "Manage")">
                                        <i class="fas fa-cog"></i> Settings
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Index", "Preferences")">
                                        <i class="fas fa-bell"></i> Preferences
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    @using (Html.BeginForm("LogOff", "Account", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item" style="width: 100%; text-align: left; border: none; background: none; cursor: pointer;">
                                            <i class="fas fa-sign-out-alt"></i> Log Off
                                        </button>
                                    }
                                </li>
                            </ul>
                        </li>
                    </ul>
                    @*Notifications Button*@
                    <a class="nav-link" href="@Url.Action("Index", "Notifications")">
                        <i class="fas fa-bell"></i> Notifications
                        @Html.Action("UnreadCount", "Notifications")
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="nav-link">Log in</a>
                    <a href="@Url.Action("Register", "Account")" class="nav-link">Register</a>
                }
            </div>
        </div>
    </header>

    <div class="main-container">
        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/site.js"></script>
    @*@Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")*@
    @RenderSection("Scripts", required: false)
</body>

</html>
